//
// v1.0, 2x1.44M, Install 
//
installer[v1.0-2x1.44m-install]:
    name = v1.0, 2x1.44M, Install 
    installid = v1.0
    mips = $(MIPS_MAX)
    rootpath = A:\
    launch = INSTALL.EXE
    anchorfile = PSTRIKE._2
    file[]: crc = e41d9a47; size =     34606; name = INSTALL.EXE
    file[]: crc = 770abd6c; size =    847872; name = PSTRIKE._1
    file[]: crc = bfbd9ee6; size =   1457147; name = PSTRIKE._2
end

