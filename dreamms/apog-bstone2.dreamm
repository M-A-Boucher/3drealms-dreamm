//
// Blake Stone: Planet Strike!
//
desc[apog-bstone2]:

name = Blake Stone: Planet Strike!
icon = apog-bstone2.png
machine = pc
osenv = dos
rootpath = C:\
launch = BS_FIRE.EXE
mips = $(MIPS_386DX_33)
ramkb = 4096
filter = apogee software, action
audiohw = sb16
videohw = vga

//
// sound configuration
//
config[sound]:
    title = Sound Configuration
    option[speaker]:
        name = $(SPEAKER_NAME)
        audiohw = speaker
    end
    option[adlib]:
        name = $(ADLIB_NAME)
        audiohw = adlib
    end
    option[sb16]:
        name = $(SB16_NAME); priority = 1
        audiohw = sb16
    end
end

//
// filesystem
//
mount[]: vpath = C:\;         srcpath = $(ifsdeltapath)  ; writable = true;
mount[]: vpath = A:\        ; srcpath = ram              ; condition = is_installer(); writable = true
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath);

script[autoinstall]:
    condition = is_installer()
    code = [[[$(CRLF)
        input_lockout(true);
        wait("int16", 0x00); keyboard_type("\r");
        wait("int16", 0x00); keyboard_type("C");
        wait("int16", 0x00); keyboard_type("N");
        input_lockout(false);
    ]]]
end

//
// v1.0
//
game[v1.0]:
    name = v1.0
    anchorfile = BS_FIRE.EXE
    file[]: crc = a858dd67; size =      1288; name = AUDIOHED.VSI
