//
// v1.1, 2x1.44M, Install 
//
installer[v1.1-2x1.44m-install]:
    name = v1.1, 2x1.44M, Install 
    installid = v1.1
    mips = $(MIPS_MAX)
    launch = DREAMM.BAT
    anchorfile = BIO123.2
    file[]: crc = bcbeda8d; size =    657408; name = BIO123.1
    file[]: crc = 00a2033e; size =    985494; name = BIO123.2
end

end