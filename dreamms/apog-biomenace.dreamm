//
// Bio Menace
//
desc[apog-biomenace]:

name = Bio Menace
icon = apog-biomenace.png
machine = pc
osenv = dos
rootpath = C:\
mips = $(MIPS_386SX_20)
nothrottle = 2
ramkb = 4096
filter = apogee software, action
audiohw = adlib

//
// episode configuration
//
config[episode]:
    title = Episode Configuration
    option[episode1]:
        name = Episode One: Dr. Mangle’s Lab
        condition = file_exists("$$(rootpath)\\BMENACE1.EXE")
        launch = BMENACE1.EXE
    end
    option[episode2]:
        name = Episode Two: The Hidden Lab
        condition = file_exists("$$(rootpath)\\BMENACE2.EXE")
        launch = BMENACE2.EXE
    end
    option[episode3]:
        name = Episode Three: Master Cain
        condition = file_exists("$$(rootpath)\\BMENACE3.EXE")
        launch = BMENACE3.EXE
    end
end

//
// graphics configuration
//
config[graphics]:
    title = Graphics Configuration
    option[cga]:
        name = $(CGA_NAME)
        videohw = cga
    end
    option[ega]:
        name = $(EGA_NAME); priority = 1
        videohw = ega
    end
    option[vga]:
        name = $(VGA_NAME)
        videohw = vga
    end
end

dynamicfile[]:
    path = $(rootpath)\DREAMM.BAT
    contents = [[[$(CRLF)
        COPY BIO123.1+BIO123.2 BIO123.EXE
        BIO123.EXE
    ]]]
end

//
// filesystem
//
mount[]: vpath = C:\;         srcpath = $(ifsdeltapath)  ; writable = true;
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath)

//
// v1.1 
//
game[v1.1]:
    name = v1.1
    anchorfile = BMENACE1.EXE
    file[]: crc = 84dfc7b8; size =       580; name = AUDIOHED.BM1
    file[]: crc = d007b1fb; size =       564; name = AUDIOHED.BM2
    file[]: crc = 7db93b51; size =       552; name = AUDIOHED.BM3
    file[]: crc = 920e8faf; size =    205754; name = AUDIOT.BM1
    file[]: crc = fdd31c14; size =    244224; name = AUDIOT.BM2
    file[]: crc = 2e831f51; size =    201662; name = AUDIOT.BM3
    file[]: crc = 04f9f981; size =     12347; name = BM-HELP.EXE ; optional = true
    file[]: crc = 38ebc6dd; size =     10315; name = BM-HINT.EXE ; optional = true
    file[]: crc = a445576c; size =     89274; name = BMENACE1.EXE
    file[]: crc = ae9296b2; size =     89231; name = BMENACE2.EXE
