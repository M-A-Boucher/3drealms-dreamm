//
// v1.0, 1x720K, Install 
//
installer[v1.0-1x720k-install]:
    name = v1.0, 1x720K, Install 
    installid = v1.0
    mips = $(MIPS_MAX)
    launch = CAVES123.EXE
    anchorfile = CAVES123.EXE
    file[]: crc = fba34f5a; size =    518204; name = CAVES123.EXE
end

//
// GOG 
//
game[gog]:
    name = GOG
    imports = v1.0
    anchorfile = CC1.EXE
    file[]: crc = 7be5f203; size =     73256; name = CC1.EXE
    file[]: crc = cf766c2e; size =     72858; name = CC2.EXE
    file[]: crc = 9c059b24; size =     75524; name = CC3.EXE
end

