//
// Crystal Caves
//
desc[apog-caves]:

name = Crystal Caves
icon = apog-caves.png
machine = pc
osenv = dos
rootpath = C:\
launch = $(EXENAME)
mips = $(MIPS_386DX_33)
nothrottle = 5
ramkb = 4096
filter = apogee software, action
audiohw = adlib
videohw = ega

//
// volume configuration
//
config[volume]:
    title = Volume Configuration
    option[volume1]:
        name = Vol 1: “Troubles with Twibbles”
        condition = file_exists("$$(rootpath)\\CC1.EXE")
        EXENAME = CC1.EXE
    end
    option[mission2]:
        name = Vol 2: “Slugging It Out”
        condition = file_exists("$$(rootpath)\\CC2.EXE")
        EXENAME = CC2.EXE
    end
    option[mission3]:
        name = Vol 3: “Mylo versus the Supernova”
        condition = file_exists("$$(rootpath)\\CC3.EXE")
        EXENAME = CC3.EXE
    end
end

//
// graphics configuration
//
config[graphics]:
    title = Graphics Configuration
    option[ega]:
        name = $(EGA_NAME); priority = 1
        videohw = ega
    end
    option[vga]:
        name = $(VGA_NAME)
        videohw = vga
    end
end

//
// filesystem
//
mount[]: vpath = C:\;         srcpath = $(ifsdeltapath)  ; writable = true;
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath)

//
// v1.0 
//
game[v1.0]:
    name = v1.0
    anchorfile = CC1.EXE
    file[]: crc = 4b469c40; size =      7320; name = CC1-1.SND
