//
// Death Rally
//
desc[apog-deathrally]:

name = Death Rally
icon = apog-deathrally.png
machine = pc
osenv = dos
rootpath = C:\
launch = $(rootpath)\RALLY.EXE
mips = $(MIPS_P100)
ramkb = 16384
videohw = svga
audiohw = sb16
filter = apogee, driving

//
// sound configuration
//
config[sound]:
    title = Sound Configuration
    option[none]:
        name = No Sound (for testing)
        SOUND_CONFIG = 0
    end
    option[sb16]:
        name = $(SB16_NAME)
        audiohw = sb16
        SOUND_CONFIG = 0x18
    end
end

//
// filesystem
//
mount[]: vpath = C:\        ; srcpath = $(ifsdeltapath)     ; writable = true;
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath)
mount[]: vpath = D:\        ; srcpath = $(ifsinstallpath)\CD; optional = true

dynamicfile[]:
    path = $(rootpath)\CDROM.INI
    contents = [[[$(CRLF)
        D:\CINEM\
    ]]]
end

dynamicfile[]:
    path = $(rootpath)\DR.CFG
    contents = [[[
        [[BINARY: $(SOUND_CONFIG) 0x07 0x01 0x20 0x02 0 0]]
    ]]]
end

//
// 1996, CD
//
game[dr]:
    name = 1996, CD
    anchorfile = RALLY.EXE
    anchordepth = 1
    file[]: crc = 75b97e11; size =     50518; name = DRHELP.EXE  ; optional = true
    file[]: crc = fe03dda8; size =    387193; name = ENGINE.BPA
    file[]: crc = bee4bf04; size =     85989; name = IBFILES.BPA
    file[]: crc = 9fba0731; size =      4797; name = LICENSE.DOC ; optional = true
    file[]: crc = 125f34fb; size =   3168933; name = MENU.BPA
    file[]: crc = d55a45d8; size =   5726559; name = MUSICS.BPA
    file[]: crc = 061b14af; size =    374621; name = RALLY.EXE
    file[]: crc = 4933689f; size =     34227; name = SETUP.EXE   ; optional = true
    file[]: crc = e5f1bcbf; size =      4616; name = STORY.TXT   ; optional = true
    file[]: crc = 18a29274; size =    337303; name = TR0.BPA
    file[]: crc = 9e4330a0; size =    321394; name = TR1.BPA
    file[]: crc = 35a834cd; size =    294365; name = TR2.BPA
    file[]: crc = efda2219; size =    345851; name = TR3.BPA
    file[]: crc = a527e402; size =    260466; name = TR4.BPA
    file[]: crc = 068f3f8e; size =    431992; name = TR5.BPA
