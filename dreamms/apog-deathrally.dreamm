    file[]: crc = 544e655d; size =    417431; name = TR7.BPA
    file[]: crc = 03e18b2e; size =    253202; name = TR8.BPA
    file[]: crc = a666efdb; size =    427555; name = TR9.BPA

    file[]: crc = fc660209; size =       156; name = CD\DISC.ID     ; optional = true
    file[]: crc = 546d2e34; size =       419; name = CD\EUREADME.TXT; optional = true
    file[]: crc = 647adeb5; size =    143353; name = CD\INST.EXE    ; optional = true
