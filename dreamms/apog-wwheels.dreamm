script[autoinstall]:
    condition = is_installer()
    code = [[[$(CRLF)
        input_lockout(true);
        wait("int16", 0x00); keyboard_type("\r");
        wait("int16", 0x00); keyboard_type("C");
        wait("int16", 0x00); keyboard_type("N");
        input_lockout(false);
    ]]]
end

