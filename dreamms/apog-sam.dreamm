//
// v1.0, 1x720K, Install 
//
installer[v1.0-1x720k-install]:
    name = v1.0, 1x720K, Install 
    installid = v1.0
    mips = $(MIPS_MAX)
    launch = SAM123.EXE
    anchorfile = SAM123.EXE
    file[]: crc = 1f60f75f; size =    564944; name = SAM123.EXE
end

//
// 3D Realms Anthology 
//
game[v1.0-anthology]:
    name = 3D Realms Anthology (v1.0)
    imports = v1.0
    anchorfile = SAM1.EXE
    file[]: crc = fef2d31f; size =     63630; name = SAM1.EXE
    file[]: crc = ad7b3621; size =     63950; name = SAM2.EXE
