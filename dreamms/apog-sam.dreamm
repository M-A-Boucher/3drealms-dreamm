//
// Secret Agent
//
desc[apog-sam]:

name = Secret Agent
icon = apog-sam.png
machine = pc
osenv = dos
rootpath = C:\
launch = $(EXENAME)
mips = $(MIPS_386DX_33)
nothrottle = 5
ramkb = 4096
filter = apogee software, action
audiohw = adlib
videohw = ega

//
// mission configuration
//
config[mission]:
    title = mission Configuration
    option[mission1]:
        name = Mission One: “The Hunt for Red Rock Rover”
        condition = file_exists("$$(rootpath)\\SAM1.EXE")
        EXENAME = SAM1.EXE
    end
    option[mission2]:
        name = Mission Two: “Kill Again Island”
        condition = file_exists("$$(rootpath)\\SAM2.EXE")
        EXENAME = SAM2.EXE
    end
    option[mission3]:
        name = Mission Three: “Dr. No Body”
        condition = file_exists("$$(rootpath)\\SAM3.EXE")
        EXENAME = SAM3.EXE
    end
end

//
// graphics configuration
//
config[graphics]:
    title = Graphics Configuration
    option[ega]:
        name = $(EGA_NAME); priority = 1
        videohw = ega
    end
    option[vga]:
        name = $(VGA_NAME)
        videohw = vga
    end
end

//
// filesystem
//
mount[]: vpath = C:\;         srcpath = $(ifsdeltapath)  ; writable = true;
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath)

//
// v1.0 
//
game[v1.0]:
    name = v1.0
    anchorfile = SAM1.EXE
    file[]: crc = abf56ada; size =     16304; name = SAM1.APO
